{
  "name": "ai-tutor-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:seed": "node prisma/seed.js",
    "config:check": "node scripts/check-config.js",
    "runtime:check": "node scripts/check-local-runtime.js",
    "deploy:check": "node scripts/check-deploy-config.js",
    "api:contract": "node scripts/check-api-contract.js",
    "frontend:contract": "node scripts/check-frontend-contract.js",
    "core:contract": "node scripts/check-core-flow-contract.js",
    "smoke:contract": "node scripts/check-smoke-contract.js",
    "schema:contract": "node scripts/check-schema-contract.js",
    "ci:contract": "node scripts/check-ci-contract.js",
    "env:contract": "node scripts/check-env-contract.js",
    "deploy:contract": "node scripts/check-deployment-contract.js",
    "stage:status": "node scripts/check-stage-status.js",
    "release:contract": "node scripts/check-release-contract.js",
    "provider:contract": "node scripts/check-provider-contract.js",
    "ops:contract": "node scripts/check-ops-contract.js",
    "db:setup": "prisma migrate deploy && node prisma/seed.js",
    "db:start:local": "node scripts/start-local-db.js",
    "db:doctor": "node scripts/check-db-doctor.js",
    "db:check": "node scripts/check-db.js",
    "smoke:api": "node scripts/smoke-api.js",
    "verify:db": "node scripts/verify-db.js",
    "verify:static": "node scripts/verify-static.js",
    "readiness:static": "node scripts/check-readiness-static.js",
    "prototype:check": "node scripts/check-prototype-static.js",
    "mobile:check": "npm --prefix ../mobile run verify:static",
    "uploads:cleanup": "node scripts/cleanup-uploads.js",
    "retention:cleanup": "node scripts/cleanup-db-retention.js",
    "reminders:run": "node scripts/send-review-reminders.js",
    "ops:check": "node scripts/check-ops-health.js",
    "ai:contract": "node scripts/check-ai-readiness-contract.js",
    "eval:ai": "node scripts/eval-ai.js",
    "ai:check": "node scripts/check-ai-provider.js"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@prisma/client": "^6.0.1",
    "fastify": "^5.1.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "prisma": "^6.0.1"
  }
}
