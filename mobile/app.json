{
  "expo": {
    "name": "AI 家庭教师",
    "slug": "ai-tutor",
    "scheme": "aitutor",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "plugins": [
      "expo-image-picker",
      "expo-notifications",
      "expo-secure-store"
    ],
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.zgc1207.aitutor",
      "infoPlist": {
        "NSCameraUsageDescription": "用于拍摄题目图片并识别题干。",
        "NSPhotoLibraryUsageDescription": "用于选择题目图片并识别题干。",
        "NSUserNotificationsUsageDescription": "用于发送错题复习提醒。"
      }
    },
    "android": {
      "package": "com.zgc1207.aitutor",
      "permissions": [
        "CAMERA",
        "READ_MEDIA_IMAGES",
        "POST_NOTIFICATIONS"
      ]
    },
    "extra": {
      "defaultApiBaseUrl": ""
    }
  }
}
