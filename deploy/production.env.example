DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/ai_tutor?schema=public"
PORT=3000
BODY_LIMIT_BYTES=8388608
SECURITY_HEADERS_ENABLED=true
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300
CORS_ALLOWED_ORIGINS="https://app.example.com,https://admin.example.com"
LLM_PROVIDER="openai"
LLM_MODEL="gpt-4o-mini"
LLM_API_KEY="replace-with-real-key"
LLM_BASE_URL="https://api.openai.com/v1"
LLM_TIMEOUT_MS=10000
LLM_MAX_OUTPUT_TOKENS=700
LLM_READY=false
OCR_PROVIDER="replace-with-real-ocr-provider"
OCR_API_KEY="replace-with-real-ocr-key"
OCR_ENDPOINT="https://ocr-provider.example.com/api"
ADMIN_TOKEN="replace-with-strong-random-token"
INTERNAL_TEST_INVITE_CODE="replace-with-invite-code-or-gated-release-code"
AUTH_OTP_SECRET="replace-with-strong-random-secret"
AUTH_OTP_DEV_MODE=false
AUTH_OTP_DELIVERY_PROVIDER="http"
AUTH_OTP_DELIVERY_ENDPOINT="https://otp-provider.example.com/send"
AUTH_OTP_DELIVERY_TOKEN="replace-with-real-token"
AUTH_OTP_TTL_MINUTES=10
AUTH_OTP_MAX_ATTEMPTS=5
AUTH_OTP_RETENTION_DAYS=7
AUTH_OTP_MIN_INTERVAL_SECONDS=60
ALLOW_LEGACY_USER_ID_AUTH=false
ALLOW_MOCK_LOGIN=false
PRODUCTION_AUTH_READY=false
OBJECT_STORAGE_READY=false
HTTPS_READY=true
DAILY_QUESTION_LIMIT=50
DAILY_AI_STEP_LIMIT=150
PLUS_DAILY_QUESTION_LIMIT=200
PLUS_DAILY_AI_STEP_LIMIT=600
PLUS_PRICE_CENTS_MONTHLY=2900
PAYMENT_PROVIDER="http"
PAYMENT_PROVIDER_ENDPOINT="https://payment-provider.example.com/checkout"
PAYMENT_PROVIDER_TOKEN="replace-with-real-token"
PAYMENT_WEBHOOK_SECRET="replace-with-real-webhook-secret"
PAYMENT_READY=false
PUSH_PROVIDER="http"
PUSH_ENDPOINT="https://push-provider.example.com/send"
PUSH_TOKEN="replace-with-real-token"
PUSH_READY=false
OPS_MAX_AI_FAILURE_RATE=0.08
OPS_MAX_DAILY_AI_COST=100
OPS_MIN_REVIEW_COMPLETION_RATE=0.5
OPS_MIN_AVERAGE_FEEDBACK_RATING=3.5
UPLOAD_RETENTION_DAYS=30
UPLOAD_STORAGE_PROVIDER="http"
UPLOAD_STORAGE_ENDPOINT="https://storage-gateway.example.com/upload"
UPLOAD_STORAGE_TOKEN="replace-with-real-token"
AI_EVENT_RETENTION_DAYS=180
EXPIRED_SESSION_RETENTION_DAYS=30
NOTIFICATION_RETENTION_DAYS=180
DISABLED_DEVICE_TOKEN_RETENTION_DAYS=180
ALLOW_PUBLIC_UPLOAD_ACCESS=false
